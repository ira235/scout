{
  "name": "scout",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "jobs:dev": "tsx --env-file=.env.local scripts/jobs-dev.ts",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "crawl": "tsx --env-file=.env.local scripts/crawl-once.ts",
    "email:preview": "email dev --dir emails"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@react-email/components": "^0.0.28",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "next": "^15.5.19",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-email": "^3.0.2",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
