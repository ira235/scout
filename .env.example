# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email)
RESEND_API_KEY=re_xxx
RESEND_FROM="Scout <alerts@scout.app>"
RESEND_WEBHOOK_SECRET=whsec_xxx

# Anthropic (Claude — prompt parsing)
ANTHROPIC_API_KEY=sk-ant-xxx

# Listing provider
LISTING_PROVIDER=mock           # mock | rentcast | rapidapi
RENTCAST_API_KEY=

# RapidAPI (US Real Estate Listings) — used when LISTING_PROVIDER=rapidapi
RAPIDAPI_KEY=
RAPIDAPI_HOST=us-real-estate-listings.p.rapidapi.com
RAPIDAPI_LIMIT=25

# Cron secret (set in Vercel cron headers as x-cron-secret)
CRON_SECRET=replace-me-with-a-long-random-string

# Public app URL (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Token signing for unsubscribe / pause links
UNSUB_SECRET=replace-me-with-a-long-random-string

# Dev: skip auth gate on /app/* and /api/* (preview app without signing in)
# Set to 1 in .env.local for local exploration. Never enable in production.
# SCOUT_SKIP_AUTH=1
